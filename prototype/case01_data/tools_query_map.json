  "bank": {
    "_tool_info": {
      "name": "东海银行 · 安全调查协作系统",
      "type": "database",
      "prerequisite_lock": "bank_system",
      "note": "需先打电话解锁。解锁后玩家拿到地址和临时账号。"
    },
    "query_types": ["客户信息", "交易流水", "受影响客户名单"],
    "queries": [
      {
        "query_type": "客户信息",
        "match": ["刘哲", "3301", "440381"],
        "result_file": "content/case01/08_liuzhe_account.txt (渲染时只显示账户信息段，不显示流水段)",
        "key_clues": ["账户尾号3301", "开户2041-01-18"]
      },
      {
        "query_type": "交易流水",
        "match": ["3301", "刘哲"],
        "result_file": "content/case01/08_liuzhe_account.txt (渲染时只显示交易流水段)",
        "key_clues": ["所有资金转向8847", "03-14 23:47 的 ¥500"]
      },
      {
        "query_type": "受影响客户名单",
        "match": ["名单", "受影响", "客户", "affected"],
        "result_file": "content/case01/07_affected_clients.txt",
        "key_clues": ["第17行刘哲 — 需要玩家自己发现，系统不标注"],
        "note": "名单也可以通过点击菜单直接获取，不需要输入搜索词"
      },
      {
        "query_type": "客户信息",
        "match": ["8847"],
        "result_file": "content/case01/10_account_b.txt",
        "key_clues": ["持有人陈芳", "手机189-7654-3210"]
      },
      {
        "query_type": "客户信息",
        "match": ["陈芳"],
        "result_file": "content/case01/10_account_b.txt",
        "note": "和查8847返回同一条记录"
      },
      {
        "query_type": "交易流水",
        "match": ["8847", "陈芳"],
        "result_summary": "收到来自3301共5笔¥381,500。ATM取现6次¥120,000（海口）。支付宝/微信¥180,000。加密货币¥78,000。余额¥3,500（已冻结）。",
        "note": "这里不给完整的资金流向分析（那是推理引擎的工作），只给原始流水"
      },
      {
        "match": ["_default"],
        "result": "未查询到该客户信息，或该客户与本案无关联。"
      }
    ]
  },

